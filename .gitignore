# ==========================================
# 1. Environment variables (CRITICAL)
# ==========================================
# Keeps your Express PORT and PostgreSQL connection strings safe!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ==========================================
# 2. Package Dependencies (Frontend & Backend)
# ==========================================
node_modules/
/frontend/node_modules/
/backend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ==========================================
# 3. Node/Express Backend Specifics
# ==========================================
# Application logs
logs
*.log
pids
*.pid
*.seed
*.pid.lock

# TypeScript build output (if using TS on backend)
/backend/dist/
/backend/build/

# Local file uploads (if users upload images/avatars to your server)
/backend/public/uploads/
/backend/uploads/

# ==========================================
# 4. PostgreSQL & Database Tools Specifics
# ==========================================
# Local database dumps (SQL backups)
*.sql
*.dump

# If using Prisma ORM
/backend/prisma/migrations/**/*.sql
.next
/prisma/db/

# If using Docker for your local PostgreSQL database
.docker/
docker-compose.override.yml

# ==========================================
# 5. Frontend Specifics (React / Vite / Next.js)
# ==========================================
/frontend/dist/
/frontend/build/
/frontend/.next/
/frontend/out/

# ==========================================
# 6. IDE and OS Files
# ==========================================
.vscode/
.idea/
.DS_Store
Thumbs.db
